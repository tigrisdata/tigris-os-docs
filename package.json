{
  "name": "tigris-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "dev": "docusaurus start --host 0.0.0.0",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "vercel-build": "[ \"$VERCEL\" = 1 ] && docusaurus build --out-dir build/docs && npm run vercel-copy-404",
    "vercel-copy-404": "[ \"$VERCEL\" = 1 ] && echo \"copying 404\" && cp build/docs/404.html build/",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "lint": "npm run lint:code && npm run lint:format",
    "lint:format": "prettier --check .",
    "lint:code": "eslint .",
    "clear": "docusaurus clear",
    "clean": "npm run clear && rm -rf node_modules",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "format": "prettier -w .",
    "build:sdk-api": "npx tsx docs/sdks/tigris/update-docs.tsx"
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@mdx-js/react": "^3.1.1",
    "@scalar/docusaurus": "^0.8.6",
    "@signalwire/docusaurus-plugin-llms-txt": "^1.2.2",
    "@social-embed/wc": "^0.1.0-next.13",
    "@vercel/edge": "^1.2.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "follow-redirects": ">=1.15.11",
    "param-case": "^4.0.0",
    "posthog-docusaurus": "^2.0.5",
    "prism-react-renderer": "^2.4.1",
    "raw-loader": "^4.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-lite-youtube-embed": "^3.5.0",
    "webpack-dev-middleware": ">=7.4.5",
    "yaml": "^1.10.2",
    "yarn": "^1.22.22"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@eslint/js": "^9.39.3",
    "@tigrisdata/storage": "^2.15.1",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "follow-redirects": ">=1.15.11",
    "globals": "^17.3.0",
    "playwright": "^1.58.2",
    "prettier": "3.8.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "webpack-dev-middleware": ">=7.4.5"
  }
}
