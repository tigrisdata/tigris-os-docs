{
  "trailingSlash": true,
  "headers": [
    {
      "source": "/docs/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/docs/llms-full.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/docs/:path*.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        }
      ]
    },
    {
      "source": "/docs/",
      "headers": [
        {
          "key": "Link",
          "value": "</docs/llms.txt>; rel=\"alternate\"; type=\"text/plain\""
        },
        {
          "key": "Vary",
          "value": "Accept"
        }
      ]
    },
    {
      "source": "/docs/:path+/",
      "headers": [
        {
          "key": "Link",
          "value": "</docs/llms.txt>; rel=\"alternate\"; type=\"text/plain\""
        },
        {
          "key": "Vary",
          "value": "Accept"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/docs/caching/",
      "destination": "/docs/objects/caching/",
      "permanent": true
    },
    {
      "source": "/docs/training/geesefs-linux/",
      "destination": "/docs/training/tigrisfs/",
      "permanent": true
    },
    {
      "source": "/docs/buckets/multi-region/",
      "destination": "/docs/buckets/locations/",
      "permanent": true
    },
    {
      "source": "/docs/objects/object_regions/",
      "destination": "/docs/buckets/locations/",
      "permanent": true
    },
    {
      "source": "/docs/objects/consistency/",
      "destination": "/docs/buckets/locations/",
      "permanent": true
    },
    {
      "source": "/docs/pricing/",
      "destination": "https://www.tigrisdata.com/pricing/",
      "permanent": true
    },
    {
      "source": "/docs/pricing/compare/",
      "destination": "https://www.tigrisdata.com/pricing/",
      "permanent": true
    },
    {
      "source": "/docs/pricing/faqs/",
      "destination": "https://www.tigrisdata.com/pricing/",
      "permanent": true
    },
    {
      "source": "/docs/get-started/",
      "destination": "/docs/",
      "permanent": true
    },
    {
      "source": "/docs/",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/markdown.*"
        }
      ],
      "destination": "/docs/index.md",
      "statusCode": 307
    },
    {
      "source": "/docs/:path+/",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/markdown.*"
        }
      ],
      "destination": "/docs/:path.md",
      "statusCode": 307
    },
    {
      "source": "/docs/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(ClaudeBot|ChatGPT-User|GPTBot|Google-Extended|PerplexityBot|Cohere-AI|OAI-SearchBot|YouBot|AI2Bot|Applebot-Extended|Meta-ExternalAgent|Meta-ExternalFetcher|Firecrawl|JinaBot).*"
        }
      ],
      "destination": "/docs/index.md",
      "statusCode": 307
    },
    {
      "source": "/docs/:path+/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(ClaudeBot|ChatGPT-User|GPTBot|Google-Extended|PerplexityBot|Cohere-AI|OAI-SearchBot|YouBot|AI2Bot|Applebot-Extended|Meta-ExternalAgent|Meta-ExternalFetcher|Firecrawl|JinaBot).*"
        }
      ],
      "destination": "/docs/:path.md",
      "statusCode": 307
    }
  ]
}
